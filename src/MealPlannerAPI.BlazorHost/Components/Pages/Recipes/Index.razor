@page "/recipes"
@using Microsoft.Extensions.Logging
@inherits AbpCrudPageBase<IRecipeAppService,
                            RecipeDto,
                            RecipeSummaryDto,
                            Guid,
                            GetRecipesInput,
                            CreateUpdateRecipeDto,
                            CreateUpdateRecipeDto >


<PageHeader>
    <PageHeaderTitle>@L["Recipes:AllRecipes"]</PageHeaderTitle>
    <PageHeaderToolbar>
        @if (HasCreatePermission)
        {
            <Button Color="Color.Primary" Clicked="OpenCreateModal">
                <Icon Name="IconName.Add" /> @L["Recipes:New"]
            </Button>
        }
    </PageHeaderToolbar>
</PageHeader>

@* ── Filters ─────────────────────────────────────────────────── *@
<Card Margin="Margin.Is3.OnY" Class="recipe-filter-card">
    <CardBody>
        <Row>
            <Column ColumnSize="ColumnSize.Is3">
                <Field>
                    <FieldLabel>@L["Common:Search"]</FieldLabel>
                    <Addons>
                        <Addon AddonType="AddonType.Start">
                            <AddonLabel><Icon Name="IconName.Search" /></AddonLabel>
                        </Addon>
                        <Addon AddonType="AddonType.Body">
                            <TextInput @bind-Value="@GetListInput.SearchTerm"
                                       Immediate="true"
                                       Placeholder="@L["Recipes:SimpleSearchPlaceholder"]" />
                        </Addon>
                    </Addons>
                </Field>
            </Column>
            <Column ColumnSize="ColumnSize.Is3">
                <Field>
                    <FieldLabel>@L["Recipes:FieldCuisine"]</FieldLabel>
                    <TextInput @bind-Value="@GetListInput.Cuisine"
                               Immediate="true"
                               Placeholder="@L["Recipes:CuisinePlaceholder"]" />
                </Field>
            </Column>
            <Column ColumnSize="ColumnSize.Is2">
                <Field>
                    <FieldLabel>@L["Unit:Difficulty"]</FieldLabel>
                    <Select TValue="DifficultyLevel?"
                            @bind-Value="@GetListInput.Difficulty">
                        <SelectItem TValue="DifficultyLevel?" Value="@(null)">@L["Recipes:FilterAll"]</SelectItem>
                        <SelectItem TValue="DifficultyLevel?" Value="@DifficultyLevel.Easy">@L["Unit:Easy"]</SelectItem>
                        <SelectItem TValue="DifficultyLevel?" Value="@DifficultyLevel.Medium">@L["Unit:Medium"]</SelectItem>
                        <SelectItem TValue="DifficultyLevel?" Value="@DifficultyLevel.Hard">@L["Unit:Hard"]</SelectItem>
                    </Select>
                </Field>
            </Column>
            <Column ColumnSize="ColumnSize.Is2">
                <Field>
                    <FieldLabel>@L["Recipes:MaxTime"] (@L["Recipes:MinShort"])</FieldLabel>
                    <NumericInput TValue="int?"
                                  @bind-Value="@GetListInput.MaxTotalTimeMinutes"
                                  Placeholder="e.g. 30"
                                  Min="0" />
                </Field>
            </Column>
            <Column ColumnSize="ColumnSize.Is2">
                <Field>
                    <FieldLabel>@L["Recipes:Vegetarian"]</FieldLabel>
                    <Select TValue="bool?" @bind-Value="@GetListInput.Vegetarian">
                        <SelectItem TValue="bool?" Value="@(null)">@L["Recipes:FilterAll"]</SelectItem>
                        <SelectItem TValue="bool?" Value="@(true)">@L["Common:Yes"]</SelectItem>
                        <SelectItem TValue="bool?" Value="@(false)">@L["Common:No"]</SelectItem>
                    </Select>
                </Field>
            </Column>
        </Row>
        <Row>
            <Column TextAlignment="TextAlignment.End">
                <Button Color="Color.Secondary"
                        Clicked="ResetFilters"
                        Margin="Margin.Is2.FromEnd">
                    <Icon Name="IconName.Redo" /> @L["Common:Reset"]
                </Button>
                <Button Color="Color.Primary" Clicked="ApplyFilters">
                    <Icon Name="IconName.Search" /> @L["Common:Search"]
                </Button>
            </Column>
        </Row>
    </CardBody>
</Card>

@* ── Results ──────────────────────────────────────────────────── *@
<Card>
    <CardHeader>
        <Row>
            <Column>
                <CardTitle>
                    @L["Recipes:TotalCount"]:
                    <Badge Color="Color.Primary">@TotalCount</Badge>
                </CardTitle>
            </Column>
        </Row>
    </CardHeader>
    <CardBody>
        <DataGrid TItem="RecipeSummaryDto"
                  Data="@Entities"
                  TotalItems="@TotalCount"
                  ShowPager="true"
                  PageSize="@PageSize"
                  Striped="true"
                  ReadData="@OnDataGridReadAsync"
                  Hoverable="true"
                  Responsive
                  Resizable="true"
                  RowClicked="(e) => GoToDetail(e.Item.Id)"
                  RowStyling="OnRowStyling">

            <DataGridColumns>

                @* Thumbnail *@
                <DataGridColumn TItem="RecipeSummaryDto" Width="Width.Px(60)">
                    <DisplayTemplate>
                        @if (!string.IsNullOrEmpty(context.Item.ImageUrl))
                        {
                            <img src="@context.Item.ImageUrl"
                                 style="width:44px; height:44px; object-fit:cover; border-radius:10px; box-shadow:0 2px 6px rgba(0,0,0,.12);" />
                        }
                        else
                        {
                            <div style="width:44px; height:44px; background:linear-gradient(135deg,#dbeafe,#ede9fe); border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:1.2rem;">
                                🍽️
                            </div>
                        }
                    </DisplayTemplate>
                </DataGridColumn>

                @* Name / Description *@
                <DataGridColumn TItem="RecipeSummaryDto" Field="@nameof(RecipeSummaryDto.Name)" Caption="@L["Recipes:Name"]">
                    <DisplayTemplate>
                        <Text TextWeight="TextWeight.SemiBold">@context.Item.Name</Text>
                        <br />
                        <Text TextColor="TextColor.Muted" Style="font-size:11px;">@context.Item.Description?.Truncate(65)</Text>
                    </DisplayTemplate>
                </DataGridColumn>

                @* Cuisine *@
                <DataGridColumn TItem="RecipeSummaryDto" Field="@nameof(RecipeSummaryDto.Cuisine)" Caption="@L["Recipes:FieldCuisine"]">
                    <DisplayTemplate>
                        @if (!string.IsNullOrEmpty(context.Item.Cuisine))
                        {
                            <span class="mp-tag">@context.Item.Cuisine</span>
                        }
                    </DisplayTemplate>
                </DataGridColumn>

                @* Difficulty *@
                <DataGridColumn TItem="RecipeSummaryDto" Field="@nameof(RecipeSummaryDto.Difficulty)" Caption="@L["Unit:Difficulty"]">
                    <DisplayTemplate>
                        <Badge Color="@GetDifficultyColor(context.Item.Difficulty)">@context.Item.Difficulty</Badge>
                    </DisplayTemplate>
                </DataGridColumn>

                @* Time *@
                <DataGridColumn TItem="RecipeSummaryDto" Field="@nameof(RecipeSummaryDto.TotalTimeMinutes)" Caption="@L["Recipes:TotalTime"]">
                    <DisplayTemplate>
                        <span class="mp-stat-chip" style="font-size:.72rem; padding:.2rem .55rem;">
                            <i class="fa-regular fa-clock"></i> @context.Item.TotalTimeMinutes @L["Recipes:MinShort"]
                        </span>
                    </DisplayTemplate>
                </DataGridColumn>

                @* Rating *@
                <DataGridColumn TItem="RecipeSummaryDto" Field="@nameof(RecipeSummaryDto.Rating)" Caption="@L["Recipes:Rating"]">
                    <DisplayTemplate>
                        <span style="font-size:.82rem;">
                            ⭐ <strong>@context.Item.Rating.ToString("F1")</strong>
                            <Text TextColor="TextColor.Muted" Style="font-size:11px;"> (@context.Item.ReviewCount)</Text>
                        </span>
                    </DisplayTemplate>
                </DataGridColumn>

                @* Tags *@
                <DataGridColumn TItem="RecipeSummaryDto" Caption="@L["Recipes:Tags"]">
                    <DisplayTemplate>
                        @foreach (var tag in context.Item.Tags.Take(3))
                        {
                            <span class="mp-tag">@tag</span>
                        }
                        @if (context.Item.Tags.Count > 3)
                        {
                            <span class="mp-tag" style="background:rgba(0,0,0,.06); color:var(--bs-secondary-color);">+@(context.Item.Tags.Count - 3)</span>
                        }
                    </DisplayTemplate>
                </DataGridColumn>

                @* Actions *@
                <DataGridEntityActionsColumn TItem="RecipeSummaryDto" @ref="@EntityActionsColumn">
                    <DisplayTemplate>
                        <div @onclick:stopPropagation="true">
                            <EntityActions TItem="RecipeSummaryDto" EntityActionsColumn="@EntityActionsColumn">
                                <EntityAction TItem="RecipeSummaryDto" Text="@L["Common:View"]"   Icon="IconName.Eye"    Clicked="() => GoToDetail(context.Item.Id)" />
                                @if (HasUpdatePermission)
                                {
                                    <EntityAction TItem="RecipeSummaryDto" Text="@L["Common:Edit"]"   Icon="IconName.Edit"   Clicked="() => OpenEditPage(context.Item.Id)" />
                                }
                                @if (HasDeletePermission)
                                {
                                    <EntityAction TItem="RecipeSummaryDto" Text="@L["Common:Delete"]" Icon="IconName.Delete" Color="Color.Danger" Clicked="() => DeleteEntityAsync(context.Item)" />
                                }
                            </EntityActions>
                        </div>
                    </DisplayTemplate>
                </DataGridEntityActionsColumn>

            </DataGridColumns>
        </DataGrid>
    </CardBody>
</Card>

@code {
    private GetRecipesInput FilterInputs = new();
    public Index()
    {
        LocalizationResource = typeof(MealPlannerAPIResource);
    }
    protected override void OnInitialized()
    {
        CurrentSorting = "Rating DESC";
        CreatePolicyName = MealPlannerAPIPermissions.Recipes.Create;
        UpdatePolicyName = MealPlannerAPIPermissions.Recipes.Update;
        DeletePolicyName = MealPlannerAPIPermissions.Recipes.Delete;
        base.OnInitialized();
    }

    protected override Task UpdateGetListInputAsync()
    {
        GetListInput.Sorting = CurrentSorting;
        return base.UpdateGetListInputAsync();
    }

    private async Task ApplyFilters()
    {
        CurrentPage = 1;
        await UpdateGetListInputAsync();
        await GetEntitiesAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task ResetFilters()
    {
        GetListInput.SearchTerm = "";
        GetListInput.Cuisine = "";
        GetListInput.Difficulty = null;
        GetListInput.MaxTotalTimeMinutes = null;
        GetListInput.Vegetarian = null;
        CurrentSorting = "Rating DESC";
        CurrentPage = 1;
        await UpdateGetListInputAsync();
        await GetEntitiesAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnSortChanged(string newSortValue)
    {
        CurrentSorting = newSortValue;
        CurrentPage = 1;
        await UpdateGetListInputAsync();
        await GetEntitiesAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void GoToDetail(Guid id)
    {
        Logger.LogInformation("Navigating to Recipe details page. RecipeId: {RecipeId}", id);
        var returnUrl = Uri.EscapeDataString(NavigationManager.Uri);
        NavigationManager.NavigateTo($"/recipes/{id}?returnUrl={returnUrl}");
    }

    private void OpenCreateModal()
    {
        Logger.LogInformation("Navigating to Create Recipe page.");
        NavigationManager.NavigateTo("/recipes/create");
    }

    private void OpenEditPage(Guid id)
    {
        Logger.LogInformation("Navigating to Edit Recipe page. RecipeId: {RecipeId}", id);
        var returnUrl = Uri.EscapeDataString(NavigationManager.Uri);
        NavigationManager.NavigateTo($"/recipes/{id}/edit?returnUrl={returnUrl}");
    }

    private void OnRowStyling(RecipeSummaryDto item, DataGridRowStyling style)
        => style.Class = "clickable-row";

    private Color GetDifficultyColor(DifficultyLevel difficulty) => difficulty switch
    {
        DifficultyLevel.Easy   => Color.Success,
        DifficultyLevel.Medium => Color.Warning,
        DifficultyLevel.Hard   => Color.Danger,
        _                      => Color.Light
    };
}