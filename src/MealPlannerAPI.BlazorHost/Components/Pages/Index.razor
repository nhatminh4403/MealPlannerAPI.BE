@page "/"
@inherits MealPlannerAPIComponentBase
@inject PageLayout PageLayout
@{
    PageLayout.Title = L["Menu:Home"];
    PageLayout.ShowToolbar = false;
}

<div class="mp-home-page">

    @* ── Hero Banner ───────────────────────────────────────────── *@
    <div class="mp-hero-banner mb-4">
        <div class="row align-items-center g-3">
            <div class="col-md-8">
                @if (!CurrentUser.IsAuthenticated)
                {
                    <span class="mp-stat-chip mb-3" style="background:rgba(255,255,255,.18); color:#fff;">
                        <i class="fa-solid fa-utensils"></i> @L["Common:Welcome"]
                    </span>
                }
                else
                {
                    <span class="mp-stat-chip mb-3" style="background:rgba(255,255,255,.18); color:#fff;">
                        <i class="fa-solid fa-hand-wave"></i> @L["Common:Welcome"], @CurrentUser.Name
                    </span>
                }
                <h3 class="mb-2">@L["LongWelcomeMessage"]</h3>
                <p class="mb-3" style="max-width:540px;">
                    Plan your meals, discover new recipes, and track your nutrition — all in one place.
                </p>
                @if (!CurrentUser.IsAuthenticated)
                {
                    <a @onclick="Login" class="btn me-2">
                        <i class="fa-solid fa-right-to-bracket me-1"></i> @L["Login"]
                    </a>
                }
                else
                {
                    <a href="/recipes" class="btn me-2">
                        <i class="fa-solid fa-book-open me-1"></i> Browse Recipes
                    </a>
                }
            </div>
            <div class="col-md-4 text-end d-none d-md-block">
                <div style="font-size:7rem; opacity:.25; line-height:1;">🥗</div>
            </div>
        </div>
    </div>

    @* ── Quick Actions ────────────────────────────────────────────── *@
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <a href="/recipes" class="mp-quick-action">
                <div class="mp-quick-action-icon" style="background: linear-gradient(135deg,#3b82f6,#6366f1);">
                    <i class="fa-solid fa-bowl-food"></i>
                </div>
                <span class="mp-quick-action-label">All Recipes</span>
                <small class="text-muted" style="font-size:.75rem;">Browse & filter</small>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a href="/recipes/trending" class="mp-quick-action">
                <div class="mp-quick-action-icon" style="background: linear-gradient(135deg,#f59e0b,#f97316);">
                    <i class="fa-solid fa-fire-flame-curved"></i>
                </div>
                <span class="mp-quick-action-label">Trending</span>
                <small class="text-muted" style="font-size:.75rem;">Hot right now</small>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a href="/recipes/top-rated" class="mp-quick-action">
                <div class="mp-quick-action-icon" style="background: linear-gradient(135deg,#10b981,#059669);">
                    <i class="fa-solid fa-star"></i>
                </div>
                <span class="mp-quick-action-label">Top Rated</span>
                <small class="text-muted" style="font-size:.75rem;">Community favourites</small>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a href="/ingredients" class="mp-quick-action">
                <div class="mp-quick-action-icon" style="background: linear-gradient(135deg,#8b5cf6,#6d28d9);">
                    <i class="fa-solid fa-leaf"></i>
                </div>
                <span class="mp-quick-action-label">Ingredients</span>
                <small class="text-muted" style="font-size:.75rem;">Nutrition lookup</small>
            </a>
        </div>
    </div>

    @* ── Info Cards ───────────────────────────────────────────────── *@
    <div class="row g-3">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header d-flex align-items-center gap-2">
                    <span style="width:8px;height:8px;border-radius:50%;background:var(--mp-primary);display:inline-block;"></span>
                    <span class="card-title">Getting Started</span>
                </div>
                <div class="card-body">
                    <ul class="mp-step-list" style="counter-reset:steps;">
                        <li>Browse the <strong>Recipes</strong> section to discover meals curated by our community.</li>
                        <li>Use the <strong>Filters</strong> to search by cuisine, difficulty, or prep time.</li>
                        <li>Click any recipe row to view full details, ingredients &amp; nutrition facts.</li>
                        <li>Admins can create, edit, or delete recipes from the same views.</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header d-flex align-items-center gap-2">
                    <span style="width:8px;height:8px;border-radius:50%;background:var(--mp-secondary);display:inline-block;"></span>
                    <span class="card-title">About Meal Planner</span>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-3" style="font-size:.9rem; line-height:1.65;">
                        Meal Planner helps you organise weekly meals, manage your ingredient pantry,
                        and understand the nutritional value of every dish — powered by the
                        <strong>ABP Framework</strong> and <strong>Blazor Server</strong>.
                    </p>
                    <div class="d-flex flex-wrap gap-2">
                        <span class="mp-stat-chip"><i class="fa-solid fa-bolt"></i> Blazor Server</span>
                        <span class="mp-stat-chip" style="background:rgba(16,185,129,.1); color:var(--mp-secondary);">
                            <i class="fa-solid fa-database"></i> ABP Framework
                        </span>
                        <span class="mp-stat-chip" style="background:rgba(245,158,11,.1); color:var(--mp-accent);">
                            <i class="fa-solid fa-apple-whole"></i> Nutrition Data
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>
